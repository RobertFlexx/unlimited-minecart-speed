  "authors": ["RobertFlexx"],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.robert.unlimitedminecarts.UnlimitedMinecartSpeed"
    ]
  },
  "mixins": [
    "unlimited_minecart_speed.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-language-kotlin": "*"
  },
  "suggests": {
    "fabric-api": "*"
  }
}
